# ---------- Kimi（Moonshot，OpenAI 兼容）多模态 ----------
# 官方文档：https://platform.moonshot.cn/
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.5

# ---------- Google Gemini（OpenAI 兼容端点）----------
# 密钥：与官方快速入门一致，优先使用环境变量 GEMINI_API_KEY（在 Google AI Studio 创建）。
# https://ai.google.dev/gemini-api/docs/quickstart?hl=zh-cn
# 本仓库用 Node `openai` SDK 调「OpenAI 兼容」地址：密钥通过 Authorization: Bearer 发送（见官方说明），
# 不是原生 REST 的 x-goog-api-key；见 https://ai.google.dev/gemini-api/docs/openai
# 若走 Vertex AI / 服务账号 OAuth，需另配 base URL 与令牌，不能仅填本项 AI Studio 式 API Key。
GEMINI_API_KEY=
# 可选：与 GEMINI_API_KEY 二选一（仅当你的密钥确实放在该变量名时再用，勿与普通 GCP API Key 混淆）
# GOOGLE_API_KEY=
# base URL 末尾建议保留斜杠 /
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# 默认 gemini-3.1-flash-lite-preview；可选 gemini-3-flash-preview（以 Google 文档为准）
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ---------- 小米 MiMo（OpenAI 兼容，全模态可用 mimo-v2-omni）----------
# 控制台与快速接入：https://platform.xiaomimimo.com/#/docs/tokenplan/quick-access
MIMO_API_KEY=
# 与 MIMO_API_KEY 二选一（部分工具使用该变量名）
# XIAOMI_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2-omni

# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# 未指定请求级 llm_provider 时的优先级：Moonshot → Gemini → MiMo → OpenAI（谁有 KEY 用谁）。
# 也可强制：LLM_PROVIDER=moonshot | gemini | mimo | openai
LLM_PROVIDER=
# 可选：统一模型名（各提供商下若未单独设置 MODEL 则回退到此项）
LLM_MODEL=
# 采样温度。Moonshot 默认 1（接口要求）；Gemini/OpenAI 默认 0.2
# LLM_TEMPERATURE=

PORT=8787
HOST=0.0.0.0
# 异步任务目录：内含 jobs.sqlite（SQLite，存任务状态与生成的 Markdown）。旧版按 UUID 建的子目录可手动删除。
DATA_DIR=./data/jobs

# 将本文件复制为 apps/server/.env 后启动：
# npm run dev:server

# ---------- 前端（构建 apps/web 时可选）----------
# 前后端不同域时，构建命令示例：VITE_API_BASE=https://你的API域名 npm run build -w @qusetion-repair/web
# VITE_API_BASE=
# 本地 Vite 代理到后端的地址。不设时，会读取 apps/server/.env 里的 PORT 自动拼出
# http://127.0.0.1:<PORT>；若仍连不上可手动指定：
# VITE_API_PROXY=http://127.0.0.1:8787
