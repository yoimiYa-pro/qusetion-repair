{
  "name": "qusetion-repair",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @qusetion-repair/core && npm run build -w @qusetion-repair/server && npm run build -w @qusetion-repair/web",
    "test": "npm run test -w @qusetion-repair/core",
    "dev": "concurrently -n server,web \"npm run dev -w @qusetion-repair/server\" \"node scripts/wait-and-start-web.mjs\"",
    "dev:server": "npm run dev -w @qusetion-repair/server",
    "dev:web": "npm run dev -w @qusetion-repair/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.1"
  }
}
